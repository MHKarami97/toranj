---
layout: null
permalink: /search.json
---
[
  {% for product in site.products %}
  {
    "title": {{ product.title | jsonify }},
    "slug": {{ product.slug | jsonify }},
    "url": {{ product.url | relative_url | jsonify }},
    "price": {{ product.price | jsonify }},
    "category": {{ product.category | jsonify }},
    "brand": {{ product.brand | jsonify }},
    "tags": {{ product.tags | jsonify }},
    "short_description": {{ product.short_description | jsonify }},
    "image": {{ product.images[0] | relative_url | jsonify }},
    "availability": {{ product.availability | jsonify }}
  }{% unless forloop.last %},{% endunless %}
  {% endfor %}
]
